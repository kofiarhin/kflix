{
  "name": "kflix-tailwind",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node server/server.js",
    "client": "npm run dev --prefix client",
    "server": "node server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "test": "npm run test:server && npm run test:client",
    "test:server": "jest --runInBand",
    "test:client": "npm run test --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "supertest": "^7.1.4"
  }
}
